APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=am
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
REVERB_APP_ID=laravel
REVERB_KEY=
REVERB_SECRET=
REVERB_HOST=reverb.laravel.com
REVERB_PORT=443
REVERB_SCHEME=https
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SENTRY_DSN=
SENTRY_ENVIRONMENT=local

SMS_ENABLED=false
SMS_BASE_URL=
SMS_API_KEY=
SMS_SENDER_ID=
SMS_TEMPLATE_APPOINTMENT_BOOKED="Your appointment {reference_code} for {service} is confirmed for {date} at {time}."
SMS_TEMPLATE_APPOINTMENT_STATUS="Your appointment {reference_code} status is {status}."
SMS_TEMPLATE_APPOINTMENT_REMINDER="Reminder: your appointment {reference_code} for {service} is tomorrow at {time}."

SMS_ENABLED=false
SMS_BASE_URL=
SMS_API_KEY=
SMS_SENDER_ID=
SMS_TEMPLATE_TICKET_CREATED="Your ticket {reference_code} has been created."
SMS_TEMPLATE_TICKET_REPLIED="Your ticket {reference_code} has a new reply. Status: {status}."
SMS_TEMPLATE_SERVICE_REQUEST_STATUS="Your request {reference_code} status: {status}."
SMS_TEMPLATE_DOCUMENT_REQUEST_SUBMITTED="Your document request {reference_code} has been received."
SMS_TEMPLATE_DOCUMENT_REQUEST_STATUS="Your document request {reference_code} status: {status}."

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
